rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "lkbimrbob@gmail.com" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'role']) &&
             data.name is string &&
             data.email is string && 
             data.role in ['admin', 'user'];
    }

    function isValidCampaign(data) {
      return data.keys().hasAll(['id', 'name', 'platform', 'tanggal']) &&
             data.name is string && data.platform in ['fb', 'google'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read, list: if isAuthenticated();
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /campaigns/{campaignId} {
      allow read, list: if isAuthenticated();
      allow create: if isAuthenticated() && isValidCampaign(request.resource.data);
      allow update: if isAuthenticated() && isValidCampaign(request.resource.data);
      allow delete: if isAdmin();
    }

    match /campaigns_data/{userId} {
      allow read, list: if isAuthenticated();
      allow write: if isAdmin() || isOwner(userId);
    }
  }
}
